<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ✅ Handler PHP sudah benar -->
    <handlers>
      <add name="FastCgiPHP" path="*.php" verb="*" modules="FastCgiModule" scriptProcessor="C:\php\php-cgi.exe" resourceType="File" />
    </handlers>

    <!-- ✅ Default Document Laravel -->
    <defaultDocument>
      <files>
        <add value="index.php" />
      </files>
    </defaultDocument>

    <!-- ✅ Tambahkan URL Rewrite Laravel -->
    <rewrite>
      <rules>
        <rule name="LaravelRoutes" stopProcessing="true">
          <match url="^(.*)$" ignoreCase="false" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php/{R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
        <staticContent>
            <mimeMap fileExtension=".shard" mimeType="application/octet-stream" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
        </staticContent>

  </system.webServer>
</configuration>
